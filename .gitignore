/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Local reference folder
/ref/
/removeQ/
/.r_libs/

# Rendered website output (comment out docs ignore when publishing with GitHub Pages)
